{
  "manifest_version": 2,
  "name": "Sbang",
  "version": "1.2",
  "description": "Custom shortcuts for Startpage",
  "browser_specific_settings": {
    "gecko": {
      "id": "sbang@local",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "permissions": [
    "storage",
    "webRequest",
    "webRequestBlocking",
    "*://*.startpage.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "48": "icon/icon48.png"
  }
}
